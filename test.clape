use Print

let x = 3.14
let y = 2.0
let z = x * y

let _ = print x
let _ = print y
let _ = print z

let cmp = x > y
let _ = print cmp

let eq = 42 == 42
let _ = print eq

let ne = 42 != 42
let _ = print ne

let _ = print (ne or eq)
let _ = print (true or false)
let _ = print (false and false)
let _ = print (false == false)
let _ = print (true and true)
let _ = print (not false or false)
