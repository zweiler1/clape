use Print

let add = (x: Int, y: Int) -> Int {
    x + y
}
let _ = print (add 3 4)

let add5 = add 5
let _ = print (add5 10)

let mul_then_add = (a: Int, b: Int, c: Int) -> Int {
    let prod = a * b;
    prod + c
}
let _ = print (mul_then_add 3 4 5)

let make_adder = (n: Int) -> (Int -> Int) {
    let inner = (x: Int) -> Int {
        x + n
    };
    inner
}
let inc = make_adder 1
let _ = print (inc 99)

let _ = print ((make_adder 10) 20)

let x = 5
let y = 10
let _ = print (x + y)
let _ = print (1 < 2 and 3 > 1)
let _ = print (not false)
let _ = print (45 + 55)

let fib = (n: Int) -> Int {
    n if n < 2 else {
        fib (n - 1) + fib (n - 2)
    }
}
let _ = print (fib 10)

let name = "Clape"
let greeting = "Hello, " + name + "!"
let _ = print greeting

let first = 'a'
let _ = print first
let _ = print ('z' > 'a')
let _ = print ('a' == 'a')

let _ = print ("he" + "llo")
let eq = (x: String, y: String) -> Bool { x == y }
let _ = print (eq "foo" "foo")
let _ = print (eq "foo" "bar")
let _ = print ("abc" != "xyz")
let _ = print ('A' < 'B')

let empty = []
let _ = print empty
let nums = [1, 2, 3]
let _ = print nums
let more = 0 :: nums
let _ = print more

let length = (xs: [Int]) -> Int {
    match xs {
        [] => 0;
        h :: t => 1 + (length t)
    }
}
let _ = print (length [10, 20, 30])

let first = (xs: [Int]) -> Int {
    match xs {
        h :: t => h
    }
}
let _ = print (first [7, 8, 9])

let _ = print ('x' :: "yz")

let append = (list: [Int], value: Int) -> [Int] {
    match list {
        [] => [value];
        h :: t => h :: append t value
    }
}
let list = [1, 2, 3, 4]
let _ = print (append list 5)
